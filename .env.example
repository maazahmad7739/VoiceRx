# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@db:5432/voicerx?schema=public"

# Redis Connection (Rate Limiting and Caching)
REDIS_URL="redis://redis:6379"

# JSON Web Token Secret
JWT_SECRET="voicerx_jwt_secret_key_change_me_in_production"

# Google Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"

# Cloudinary URL (Optional - falls back to local disk storage if omitted)
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=""

# Server Ports
PORT=5000
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
FRONTEND_URL="http://localhost:3000"
