# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/voicerx?schema=public"

# Redis Connection (Rate Limiting and Caching)
REDIS_URL="redis://localhost:6379"

# JSON Web Token Secret
JWT_SECRET="generate-a-secure-random-token-here"

# Google Gemini API Key
GEMINI_API_KEY="your-gemini-api-key"

# Cloudinary URL (Optional)
CLOUDINARY_URL=""

# Server Ports
PORT=5000
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
FRONTEND_URL="http://localhost:3000"

# SMTP Production Mailer (For Forgot Password Recovery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="VoiceRx Portal" <no-reply@voicerx.in>
